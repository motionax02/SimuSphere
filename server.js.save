apiKey: '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
' });

app.post('/ask', async (req, res) => {
  const { question, component } = req.body;
  const completion = await openai.chat.completions.create({
    model: 'gpt-4o-mini',
    messages: [
      {
        role: 'system',
        content: `You are VIS-7, an AI assistant for vessel inspection at Saudi Aramco CGPD. The inspector is viewing: ${component}. Answer technically and concisely in under 100 words.`
      },
      { role: 'user', content: question }
    ]
  });
  res.json({ answer: completion.choices[0].message.content });
});

app.listen(3000, () => console.log('SimuSphere running on http://localhost:3000'));

